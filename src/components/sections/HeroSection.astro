---
import ProtocolConstellation from '../islands/ProtocolConstellation';

const features = [
  {
    title: 'IETF Draft',
    description: 'Read the standard',
    href: 'https://datatracker.ietf.org/doc/draft-ietf-ocm-open-cloud-mesh/',
    logo: '/logos/ietf.svg',
  },
  {
    title: 'OCM API',
    description: 'View the specification',
    href: 'https://cs3org.github.io/OCM-API/',
    logo: '/logos/ocm-logo.svg',
  },
  {
    title: 'CS3 Community',
    description: 'Join the cloud storage sync & share community',
    href: 'https://cs3community.org/',
    logo: '/logos/cs3.png',
  },
  {
    title: 'Matrix Chat',
    description: 'Join discussions',
    href: 'https://matrix.to/#/#ocm:matrix.org',
    logo: '/logos/matrix.svg',
  },
];
---

<section class="relative flex min-h-full w-full flex-1 flex-col overflow-hidden">
  <div class="absolute inset-0 z-0">
    <ProtocolConstellation client:load />
  </div>

  <!-- Ambient cyan gradient overlay -->
  <div
    class="absolute inset-0 z-[1] pointer-events-none"
    style="background: radial-gradient(ellipse 120% 80% at 25% 30%, hsla(186, 55%, 50%, 0.30) 0%, transparent 60%), radial-gradient(ellipse 100% 60% at 75% 70%, hsla(180, 50%, 45%, 0.18) 0%, transparent 55%), radial-gradient(ellipse 80% 50% at 50% 50%, hsla(190, 45%, 48%, 0.10) 0%, transparent 70%);"
  ></div>

  <div class="relative z-10 mx-auto flex w-full max-w-7xl flex-1 flex-col items-center justify-center px-6 py-8 pointer-events-none">
    <div class="text-center mb-6">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight drop-shadow-lg text-white">
        Open Cloud Mesh
      </h1>
      <p class="mt-3 text-lg md:text-xl text-gray-200 max-w-2xl mx-auto drop-shadow-md">
        A server federation protocol that lets users share files, folders, and other resources across different cloud platforms
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full">
      {features.map(feature => (
        <a
          href={feature.href}
          target={feature.href.startsWith('http') ? '_blank' : undefined}
          rel={feature.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="group flex flex-col items-center text-center bg-gray-900/80 border border-gray-800 rounded-xl p-5 hover:border-blue-500/50 hover:-translate-y-1 transition-all duration-200 pointer-events-auto"
        >
          <div class="w-16 h-16 flex items-center justify-center mb-3">
            <img
              src={feature.logo}
              alt={feature.title}
              class={`w-full h-full object-contain opacity-90 group-hover:opacity-100 transition-opacity ${feature.title === 'Matrix Chat' ? 'filter brightness-0 invert' : ''}`}
            />
          </div>
          <h3 class="text-white font-semibold text-base mb-1">{feature.title}</h3>
          <p class="text-gray-500 text-xs leading-relaxed">{feature.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
